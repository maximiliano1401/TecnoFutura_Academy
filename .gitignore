# TecnoFutura Academy - .gitignore

# Archivos de sistema operativo
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDEs y editores
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath

# PHP
*.log
*.cache
error_log
php_errors.log

# Composer
vendor/
composer.lock

# Node modules (si usas Node.js en el futuro)
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# Archivos temporales
*.tmp
*.temp
*.bak
*.backup

# Archivos de configuración local
config.local.php
.env
.env.local

# Carpeta de subidas de usuarios
uploads/*
!uploads/.gitkeep

# Archivos de base de datos
*.sql
*.sqlite
*.db

# Logs
logs/
*.log

# Cache
cache/
tmp/

# Imágenes temporales o de prueba (excepto logo)
img/temp/
img/test/

# Archivos de sistema de Windows
$RECYCLE.BIN/

# Archivos de macOS
.AppleDouble
.LSOverride

# Archivos de Linux
.directory

# Backups automáticos
*~
*.swn

# PHPStorm
.idea/

# VS Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# NetBeans
nbproject/

# Eclipse
.buildpath
.project
.settings/

# Archivos de sesión PHP
sessions/

# Archivos sensibles
credentials.php
keys.php
secrets.php
